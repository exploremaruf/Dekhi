<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Dekhi" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/lt_window_bg</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="colorPrimary">@color/lt_primary</item>
        <item name="colorSecondary">@color/lt_secondary</item>
        <item name="colorSurface">@color/lt_surface</item>
        <item name="colorSurfaceVariant">@color/lt_surface_variant</item>
        <item name="colorOnSurface">@color/lt_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/lt_on_surface_variant</item>
        <item name="colorOutline">@color/lt_outline</item>

        <!-- Material 3 text styles mapping -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Dekhi.HeadlineLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Dekhi.TitleMedium</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Dekhi.BodyMedium</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/lt_window_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="postSplashScreenTheme">@style/Theme.Dekhi</item>
    </style>

    <!-- Typography Design Tokens -->
    <style name="TextAppearance.Dekhi.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Dekhi.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Dekhi.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Compatibility Styles for Layouts -->
    <style name="TextAppearance.Dekhi.Header" parent="TextAppearance.Dekhi.TitleMedium" />
    <style name="TextAppearance.Dekhi.Headline" parent="TextAppearance.Dekhi.HeadlineLarge" />
    <style name="TextAppearance.Dekhi.Title" parent="TextAppearance.Dekhi.TitleMedium" />
    <style name="TextAppearance.Dekhi.Body" parent="TextAppearance.Dekhi.BodyMedium" />

    <style name="Widget.Dekhi.Card.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
