<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cinematic_background"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Dekhi.TextInputLayout"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/cinematic_text_secondary"
            app:endIconMode="clear_text"
            app:endIconTint="@color/cinematic_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search_playlists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search Collections..."
                android:inputType="text"
                android:textColor="@color/cinematic_text_primary"
                android:background="@color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_import"
            style="@style/Widget.Dekhi.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Import New Playlist"
            android:textColor="@color/white"
            app:icon="@android:drawable/ic_menu_add"
            app:iconTint="@color/white"
            android:backgroundTint="@color/cinematic_indicator"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_playlists"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_playlist" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:alpha="0.2"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Your collection is empty"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/white"
                android:alpha="0.8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Import an M3U playlist to start organizing your cinematic experience."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/cinematic_text_secondary" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
