<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Dekhi.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="12dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_playlist_logo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@color/cinematic_divider"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                app:tint="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_playlist_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/white"
                app:layout_constraintStart_toEndOf="@+id/iv_playlist_logo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_delete"
                tools:text="Action Movies" />

            <TextView
                android:id="@+id/tv_playlist_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/cinematic_text_secondary"
                app:layout_constraintStart_toEndOf="@+id/iv_playlist_logo"
                app:layout_constraintTop_toBottomOf="@+id/tv_playlist_name"
                app:layout_constraintEnd_toStartOf="@+id/btn_delete"
                tools:text="1200 Channels • 45 Groups" />

            <TextView
                android:id="@+id/tv_playlist_updated"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/cinematic_text_secondary"
                android:alpha="0.6"
                app:layout_constraintStart_toEndOf="@+id/iv_playlist_logo"
                app:layout_constraintTop_toBottomOf="@+id/tv_playlist_meta"
                app:layout_constraintEnd_toStartOf="@+id/btn_delete"
                tools:text="Updated 2 hours ago" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/cinematic_text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
