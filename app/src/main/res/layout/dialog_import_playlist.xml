<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_transparent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Import Collection"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:layout_marginBottom="32dp"
        android:textColor="@color/white" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.Dekhi.TextInputLayout"
        app:startIconDrawable="@android:drawable/ic_menu_edit"
        app:startIconTint="@color/cinematic_text_secondary"
        app:boxBackgroundColor="@color/transparent"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_playlist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name your playlist"
            android:textColorHint="@color/cinematic_text_secondary"
            android:inputType="textCapWords"
            android:paddingTop="18dp"
            android:paddingBottom="8dp"
            android:textColor="@color/white"
            android:background="@color/transparent" />

    </com.google.android.material.textfield.TextInputLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/cinematic_divider"
        android:layout_marginHorizontal="4dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        style="@style/Widget.Dekhi.TextInputLayout"
        app:startIconDrawable="@drawable/media3_icon_feed"
        app:startIconTint="@color/cinematic_text_secondary"
        app:boxBackgroundColor="@color/transparent"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_playlist_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter playlist URL"
            android:textColorHint="@color/cinematic_text_secondary"
            android:inputType="textUri"
            android:paddingTop="18dp"
            android:paddingBottom="8dp"
            android:textColor="@color/white"
            android:background="@color/transparent" />

    </com.google.android.material.textfield.TextInputLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/cinematic_divider"
        android:layout_marginHorizontal="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:text="@string/or"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textColor="@color/cinematic_text_secondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pick_file"
        style="@style/Widget.Dekhi.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/pick_m3u_file"
        app:icon="@android:drawable/ic_menu_save"
        app:iconTint="@color/white" />

</LinearLayout>
