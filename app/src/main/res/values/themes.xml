<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Dekhi" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/surface_base</item>
        <item name="android:navigationBarColor">@color/surface_base</item>
        <item name="android:statusBarColor">@color/surface_base</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSecondaryContainer">@color/primary</item>

        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/surface_elevated</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/text_med_emph</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/surface_base</item>
        <item name="colorOnSurface">@color/text_high_emph</item>
        <item name="colorSurfaceVariant">@color/surface_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_med_emph</item>

        <item name="colorError">@color/cinematic_error</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Dekhi.HeroTitle</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Dekhi.HeroTitle</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Dekhi.SectionTitle</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Dekhi.Body</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Dekhi.Caption</item>

        <item name="materialCardViewStyle">@style/Widget.Dekhi.Card</item>
        <item name="materialButtonStyle">@style/Widget.Dekhi.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.Dekhi.TextInputLayout</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface_base</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="postSplashScreenTheme">@style/Theme.Dekhi</item>
    </style>

    <style name="TextAppearance.Dekhi.HeroTitle" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_high_emph</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textSize">34sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <style name="TextAppearance.Dekhi.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_high_emph</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Dekhi.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_high_emph</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Dekhi.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_med_emph</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.Dekhi.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_elevated</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">@color/stroke_divider</item>
    </style>

    <style name="Widget.Dekhi.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/surface_base</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Dekhi.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.Dekhi.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">28dp</item>
        <item name="boxCornerRadiusTopEnd">28dp</item>
        <item name="boxCornerRadiusBottomStart">28dp</item>
        <item name="boxCornerRadiusBottomEnd">28dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxBackgroundColor">@color/surface_elevated</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="Widget.Dekhi.Card.Flat" parent="Widget.Dekhi.Card" />

    <style name="SettingsHeader" parent="TextAppearance.Dekhi.Caption">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">32dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsCard" parent="Widget.Dekhi.Card">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="SettingsContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="SettingsItem" parent="TextAppearance.Dekhi.Body">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="SettingsSwitch" parent="SettingsItem">
        <item name="android:background">@null</item>
    </style>

</resources>
